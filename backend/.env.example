# Configuración de The Lobby Beauty API
# Copia este archivo como .env y rellena los valores

# Supabase - Obtén estos valores desde tu proyecto en supabase.com
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key-aqui

# Aplicación
DEBUG=true

# CORS - URLs permitidas (separadas por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT (opcional, Supabase maneja la autenticación)
SECRET_KEY=cambia-esta-clave-en-produccion
